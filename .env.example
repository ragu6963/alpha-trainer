# ===========================================
# Alpha Trainer - 환경 변수 설정
# ===========================================
# 이 파일을 .env.local로 복사하여 실제 값을 입력하세요.
# cp .env.example .env.local

# -------------------------------------------
# Supabase
# -------------------------------------------
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -------------------------------------------
# Strava OAuth
# -------------------------------------------
# https://www.strava.com/settings/api 에서 앱 생성 후 확인
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:3000/api/auth/strava/callback
# 쉼표로 구분된 허용 athlete ID 목록. 설정 시 해당 계정만 가입 가능.
# 비워두면 누구나 가입 가능 (공개 서비스 모드)
ALLOWED_STRAVA_ATHLETE_IDS=your-strava-athlete-id

# -------------------------------------------
# App
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------
# Database (Supabase > Settings > Database > Connection string > URI)
# -------------------------------------------
DATABASE_URL="postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
