generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(uuid())
  supabaseId      String    @unique
  stravaAthleteId Int?      @unique
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  lastSyncedAt    DateTime?
  birthYear       Int?
  measuredMaxHR   Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  activities    Activity[]
  conversations Conversation[]
  llmKeys       UserLLMKey[]
  goal          UserGoal?
}

model Activity {
  id                 String   @id @default(uuid())
  stravaActivityId   BigInt   @unique
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name               String
  distance           Float
  movingTime         Int
  elapsedTime        Int
  startDate          DateTime
  averageSpeed       Float
  maxSpeed           Float
  averageHeartrate   Float?
  maxHeartrate       Float?
  totalElevationGain Float
  elevHigh           Float?
  elevLow            Float?
  startLatlng        Json?
  endLatlng          Json?
  // Detail fields (fetched from /activities/{id})
  description        String?
  calories           Float?
  sufferScore        Float?
  averageCadence     Float?
  splitsMetric       Json?
  createdAt          DateTime @default(now())

  laps               Lap[]
}

model Lap {
  id                 String   @id @default(uuid())
  stravaLapId        BigInt   @unique
  activityId         String
  activity           Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  lapIndex           Int
  name               String
  elapsedTime        Int
  movingTime         Int
  distance           Float
  startDate          DateTime
  averageSpeed       Float
  maxSpeed           Float
  totalElevationGain Float
  averageCadence     Float?
  averageHeartrate   Float?
  maxHeartrate       Float?
  startIndex         Int
  endIndex           Int
  paceZone           Int?
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  messages Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())
}

enum MessageRole {
  user
  assistant
}

model UserLLMKey {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     LLMProvider
  model        String
  vaultSecretId String
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
}

enum LLMProvider {
  gemini
  openai
  anthropic
}

enum GoalType {
  race_completion
  pace_improvement
  distance_increase
  frequency
}

model UserGoal {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalType             GoalType
  targetRaceDate       DateTime?
  targetRaceName       String?
  targetDistanceKm     Float?
  targetFinishTime     String?
  weeklyDistanceGoalKm Float?
  weeklyRunCountGoal   Int?
  memo                 String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}
